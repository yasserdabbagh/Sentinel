<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sentinel – MVP | KSA Construction Risk Intelligence</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.plot.ly/plotly-2.27.0.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <!-- Application Structure Plan:
         1. Dynamic Header: Updates to the viewer's current date/time.
         2. Global Risk Pulse: High-level PERI and Outlook status cards.
         3. Intelligence Clusters: 18-cluster heatmap for deep-dive analysis.
         4. Operational Indices: Radar chart comparing current sector health to baseline.
         5. Scenario Modeling: Interactive projection tool.
    -->

    <!-- CONFIRMATION: NO SVG graphics used. NO Mermaid JS used. -->

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: { sans: ['Outfit', 'sans-serif'] },
                    colors: {
                        brand: {
                            dark: '#0f172a',
                            navy: '#1e293b',
                            sky: '#0ea5e9',
                            amber: '#f59e0b',
                            rose: '#f43f5e',
                            emerald: '#10b981'
                        }
                    }
                }
            }
        }
    </script>

    <style>
        .chart-container { position: relative; width: 100%; margin: auto; height: 350px; max-height: 400px; }
        .chart-container-lg { height: 500px; max-height: 550px; }
        .status-pill { padding: 2px 8px; border-radius: 9999px; font-size: 10px; font-weight: 700; text-transform: uppercase; }
        .nav-link:hover { color: #0ea5e9; }
        .scenario-btn.active { background: #0ea5e9; color: white; border-color: #0ea5e9; }
    </style>
</head>
<body class="bg-slate-50 text-slate-900 selection:bg-sky-100">

    <!-- DYNAMIC HEADER -->
    <nav class="sticky top-0 z-50 bg-white/80 backdrop-blur-md border-b border-slate-200">
        <div class="container mx-auto px-6 h-16 flex justify-between items-center">
            <div>
                <h1 class="font-bold text-slate-900 text-xl tracking-tighter">SENTINEL – MVP</h1>
                <p class="text-[10px] text-slate-500 font-bold uppercase tracking-widest leading-none">Intelligence Command Center</p>
            </div>
            <div class="hidden lg:flex space-x-8 text-sm font-medium text-slate-600">
                <a href="#pulse" class="nav-link">Risk Pulse</a>
                <a href="#clusters" class="nav-link">Intelligence Clusters</a>
                <a href="#operational" class="nav-link">Operational Health</a>
                <a href="#modeling" class="nav-link">Scenario Modeling</a>
            </div>
            <div class="text-right">
                <div id="live-clock" class="text-xs font-mono text-slate-400 font-bold">--:--:--</div>
                <div id="report-date" class="text-[10px] text-brand-sky font-bold uppercase tracking-tighter">OCTOBER 24, 2023</div>
            </div>
        </div>
    </nav>

    <main class="container mx-auto px-4 py-8 max-w-7xl space-y-10">

        <!-- GLOBAL RISK PULSE -->
        <section id="pulse" class="grid grid-cols-1 lg:grid-cols-3 gap-6">
            <div class="lg:col-span-2 bg-white p-8 rounded-3xl border border-slate-200 shadow-sm flex flex-col md:flex-row items-center gap-8">
                <div class="w-full md:w-1/2">
                    <h2 class="text-2xl font-bold mb-2">Master PERI Index</h2>
                    <p class="text-sm text-slate-500 mb-6">Composite index weighing Political (35%), Economic (40%), and Poly-Econ Interplay (25%).</p>
                    <div id="peri-gauge" class="w-full h-[220px]"></div>
                </div>
                <div class="w-full md:w-1/2 space-y-4">
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-xs font-bold text-slate-500">Economic Stress (ERS)</span>
                            <span class="status-pill bg-rose-100 text-rose-600">High</span>
                        </div>
                        <div class="w-full bg-slate-200 h-1.5 rounded-full">
                            <div class="bg-rose-500 h-1.5 rounded-full" style="width: 75%"></div>
                        </div>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-xs font-bold text-slate-500">Political Stability (PRS)</span>
                            <span class="status-pill bg-emerald-100 text-emerald-600">Stable</span>
                        </div>
                        <div class="w-full bg-slate-200 h-1.5 rounded-full">
                            <div class="bg-emerald-500 h-1.5 rounded-full" style="width: 42%"></div>
                        </div>
                    </div>
                    <div class="p-4 bg-slate-50 rounded-2xl border border-slate-100">
                        <div class="flex justify-between items-center mb-1">
                            <span class="text-xs font-bold text-slate-500">Poly-Interaction (PIS)</span>
                            <span class="status-pill bg-amber-100 text-amber-600">Elevated</span>
                        </div>
                        <div class="w-full bg-slate-200 h-1.5 rounded-full">
                            <div class="bg-amber-500 h-1.5 rounded-full" style="width: 68%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="bg-brand-dark text-white p-8 rounded-3xl shadow-xl flex flex-col justify-between">
                <div>
                    <h3 class="text-lg font-bold text-brand-sky mb-1">Sector Outlook</h3>
                    <div class="text-4xl font-black mb-4">ELEVATED</div>
                    <p class="text-xs text-slate-400 leading-relaxed">
                        The current 90-day trajectory indicates significant friction in material procurement due to global shipping re-routing and a high-rate environment impacting SAIBOR.
                    </p>
                </div>
                <div class="mt-8 pt-6 border-t border-slate-700">
                    <div class="text-[10px] font-bold text-slate-500 uppercase mb-2">Primary Mitigation Trigger</div>
                    <div class="text-sm font-bold bg-slate-800 p-3 rounded-xl border border-slate-700">
                        Lock 180-day commodity pricing hedges immediately.
                    </div>
                </div>
            </div>
        </section>

        <!-- INTELLIGENCE CLUSTERS -->
        <section id="clusters" class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm">
            <div class="mb-8 flex flex-col md:flex-row justify-between items-start md:items-center gap-4">
                <div>
                    <h2 class="text-2xl font-bold">18-Cluster Risk Heatmap</h2>
                    <p class="text-sm text-slate-500">Mapping likelihood vs financial impact across the full Sentinel Universe.</p>
                </div>
                <div class="flex items-center gap-4 text-xs font-bold text-slate-500">
                    <div class="flex items-center gap-1"><span class="w-3 h-3 bg-slate-100 rounded"></span> Low</div>
                    <div class="flex items-center gap-1"><span class="w-3 h-3 bg-brand-sky rounded"></span> Med</div>
                    <div class="flex items-center gap-1"><span class="w-3 h-3 bg-brand-rose rounded"></span> High</div>
                </div>
            </div>
            <div id="risk-heatmap" class="w-full h-[450px]"></div>
        </section>

        <!-- OPERATIONAL HEALTH -->
        <section id="operational" class="grid grid-cols-1 lg:grid-cols-2 gap-8">
            <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm">
                <h3 class="text-xl font-bold mb-6 text-center">Sector Health vs Baseline</h3>
                <div class="chart-container">
                    <canvas id="radar-indices"></canvas>
                </div>
            </div>
            <div class="bg-white p-8 rounded-3xl border border-slate-200 shadow-sm">
                <h3 class="text-xl font-bold mb-6">Top 10 High-Urgency Risks</h3>
                <div class="chart-container">
                    <canvas id="top-risks-bar"></canvas>
                </div>
            </div>
        </section>

        <!-- SCENARIO MODELING -->
        <section id="modeling" class="bg-white rounded-3xl border border-slate-200 shadow-sm overflow-hidden">
            <div class="p-8 border-b border-slate-100 bg-slate-50 flex flex-col md:flex-row justify-between items-center gap-6">
                <div class="max-w-md">
                    <h2 class="text-2xl font-bold">90-Day Forecast Simulator</h2>
                    <p class="text-sm text-slate-500">Projecting aggregate sector risk based on macro-shocks.</p>
                </div>
                <div class="flex bg-white p-1 rounded-full border border-slate-200">
                    <button onclick="changeScenario('base')" id="btn-base" class="scenario-btn active px-4 py-2 text-xs font-bold rounded-full transition-all">Base Case</button>
                    <button onclick="changeScenario('oil')" id="btn-oil" class="scenario-btn px-4 py-2 text-xs font-bold rounded-full transition-all">Oil Drop (-15%)</button>
                    <button onclick="changeScenario('geo')" id="btn-geo" class="scenario-btn px-4 py-2 text-xs font-bold rounded-full transition-all">Regional Stress</button>
                </div>
            </div>
            <div class="p-8">
                <div class="chart-container-lg">
                    <canvas id="forecast-line"></canvas>
                </div>
                <div id="scenario-intel" class="mt-8 p-6 bg-sky-50 rounded-2xl border border-sky-100 text-sm text-sky-900 leading-relaxed font-medium italic">
                    "Intelligence suggests a stable trajectory with moderate upward pressure on financing costs as KSA interest rates track US federal policy."
                </div>
            </div>
        </section>

    </main>

    <footer class="py-12 bg-slate-900 text-slate-500 text-center">
        <p class="text-sm font-bold tracking-tight text-white mb-1 uppercase">Sentinel – MVP | KSA Risk Intelligence</p>
        <p class="text-[10px] tracking-widest uppercase mb-6">Sector Assessment Command • Confidential</p>
        <p class="text-[9px] max-w-lg mx-auto leading-relaxed">This report uses probabilistic modeling based on public macro-indicators. It is an analytical tool for professional assessment and does not constitute financial advice.</p>
    </footer>

    <script>
        // --- CLOCK & DATE LOGIC (Updates UI based on viewer's local time) ---
        function updateClock() {
            const now = new Date();
            const clock = document.getElementById('live-clock');
            const dateDisplay = document.getElementById('report-date');
            
            clock.textContent = now.toLocaleTimeString('en-US', { hour12: false, hour: '2-digit', minute: '2-digit', second: '2-digit' });
            dateDisplay.textContent = now.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' }).toUpperCase();
        }
        setInterval(updateClock, 1000);
        updateClock();

        // --- CHART INITIALIZATION ---
        Chart.defaults.font.family = "'Outfit', sans-serif";
        Chart.defaults.color = '#64748b';

        // 1. PERI GAUGE (Plotly)
        const gaugeData = [{
            type: "indicator",
            mode: "gauge+number",
            value: 58.4,
            number: { font: { size: 40, color: "#0f172a" } },
            gauge: {
                axis: { range: [0, 100], tickwidth: 1 },
                bar: { color: "#0ea5e9" },
                steps: [
                    { range: [0, 40], color: "#dcfce7" },
                    { range: [40, 60], color: "#ffedd5" },
                    { range: [60, 100], color: "#fee2e2" }
                ],
                threshold: { line: { color: "red", width: 4 }, thickness: 0.75, value: 80 }
            }
        }];
        Plotly.newPlot('peri-gauge', gaugeData, { margin: { t: 0, b: 0, l: 30, r: 30 }, paper_bgcolor: 'transparent' }, { responsive: true, displayModeBar: false });

        // 2. RISK HEATMAP (Plotly)
        const heatmapZ = [
            [45, 62, 58, 40, 52, 65], // Impact
            [35, 78, 88, 42, 55, 72], // Likelihood
            [40, 70, 73, 41, 54, 68]  // Score
        ];
        const heatmapX = ['Political', 'Economic', 'Financial', 'Strategic', 'Market', 'Delivery'];
        const heatmapY = ['Impact', 'Likelihood', 'Agg. Score'];
        Plotly.newPlot('risk-heatmap', [{
            z: heatmapZ, x: heatmapX, y: heatmapY, type: 'heatmap',
            colorscale: [[0, '#f8fafc'], [0.5, '#0ea5e9'], [1, '#f43f5e']],
            showscale: false
        }], { margin: { t: 20, b: 40, l: 80, r: 20 }, paper_bgcolor: 'transparent', font: { size: 10 } }, { responsive: true, displayModeBar: false });

        // 3. RADAR INDICES (Chart.js)
        const radarCtx = document.getElementById('radar-indices').getContext('2d');
        const radarChart = new Chart(radarCtx, {
            type: 'radar',
            data: {
                labels: ['Delay', 'Cost Overrun', 'Supplier Fail', 'Cash Flow', 'HSE', 'Contracts', 'Workforce', 'Supply Chain'],
                datasets: [{
                    label: 'Current Status',
                    data: [65, 78, 55, 82, 35, 60, 55, 72],
                    borderColor: '#0ea5e9',
                    backgroundColor: 'rgba(14, 165, 233, 0.2)',
                    pointBackgroundColor: '#0ea5e9',
                }, {
                    label: '5-Year Sector Baseline',
                    data: [40, 40, 40, 40, 40, 40, 40, 40],
                    borderColor: '#94a3b8',
                    borderDash: [5, 5],
                    fill: false,
                    pointRadius: 0
                }]
            },
            options: { maintainAspectRatio: false, scales: { r: { suggestedMin: 0, suggestedMax: 100, ticks: { display: false } } } }
        });

        // 4. TOP RISKS BAR (Chart.js)
        const barCtx = document.getElementById('top-risks-bar').getContext('2d');
        new Chart(barCtx, {
            type: 'bar',
            data: {
                labels: ['Liquidity', 'Materials', 'Lead Times', 'Labor', 'Interest', 'Contracts', 'Geopolitics', 'Policy', 'Cyber', 'Quality'],
                datasets: [{
                    data: [88, 85, 82, 75, 72, 70, 68, 62, 45, 40],
                    backgroundColor: '#1e293b',
                    borderRadius: 6
                }]
            },
            options: { indexAxis: 'y', maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { grid: { display: false } } } }
        });

        // 5. FORECAST LINE (Interactive)
        let forecastChart;
        const scenarios = {
            base: { data: [58.4, 60.2, 63.5, 62.1, 65.8, 68.2, 66.5], intel: "Intelligence suggests a stable trajectory with moderate upward pressure on financing costs as KSA interest rates track US federal policy." },
            oil: { data: [58.4, 65.1, 75.8, 82.5, 78.0, 75.1, 72.4], intel: "Scenario Alert: A sustained oil price drop below $75 triggers government budget shifts and payment cycle expansion (Day 30-60 impact)." },
            geo: { data: [58.4, 62.0, 78.5, 92.4, 94.5, 91.2, 88.0], intel: "Critical Alert: Regional escalation disrupts Red Sea logistics. Procurement lead times breach 200%, resulting in widespread Force Majeure claims." }
        };

        const forecastCtx = document.getElementById('forecast-line').getContext('2d');
        forecastChart = new Chart(forecastCtx, {
            type: 'line',
            data: {
                labels: ['Day 0', 'Day 15', 'Day 30', 'Day 45', 'Day 60', 'Day 75', 'Day 90'],
                datasets: [{
                    label: 'Risk Index',
                    data: scenarios.base.data,
                    borderColor: '#0ea5e9',
                    backgroundColor: 'rgba(14, 165, 233, 0.05)',
                    fill: true,
                    tension: 0.4,
                    pointRadius: 4,
                    pointHoverRadius: 8
                }]
            },
            options: { maintainAspectRatio: false, scales: { y: { min: 40, max: 100 } }, plugins: { legend: { display: false } } }
        });

        function changeScenario(type) {
            document.querySelectorAll('.scenario-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('btn-' + type).classList.add('active');
            
            forecastChart.data.datasets[0].data = scenarios[type].data;
            forecastChart.update();
            document.getElementById('scenario-intel').innerText = scenarios[type].intel;
        }

    </script>
</body>
</html>
